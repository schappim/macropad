{
    "title": "Macropad mappings (VID 20812 / PID 34897)",
    "rules": [
        {
            "description": "Macropad: Cmd+1 → Cmd+Shift+Tab (app switcher back)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "1",
                        "modifiers": { "mandatory": ["command"] }
                    },
                    "to": [{ "key_code": "tab", "modifiers": ["left_command", "left_shift"] }],
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [{ "vendor_id": 20812, "product_id": 34897 }]
                        }
                    ]
                }
            ]
        },
        {
